{"type":"message-part","messageId":"1a0becb9-3259-4343-8c71-3c275a57f630","role":"assistant","index":11,"part":{"type":"tool-writeToFile","toolCallId":"hNgCErc3EnfaSIXh","state":"input-streaming","input":{"content":"const express = require('express');\nconst axios = require('axios');\n\nconst app = express();\nconst port = 3000;\n\napp.use(express.json());\n\napp.post('/verify-bvn', async (req, res) => {\n  const { bvn } = req.body;\n\n  if (!bvn) {\n    return res.status(400).json({ error: 'BVN is required' });\n  }\n\n  try {\n    const response = await axios.post(\n      'https://api.prembly.com/verification/bvn',\n      { bvn },\n      {\n        headers: {\n          'app-id': process.env.PREMBLY_APP_ID,\n          'x-api-key': process.env.PREMBLY_API_KEY,\n          'Content-Type': 'application/json'\n        }\n      }\n    );\n\n    res.status(response.status).json(response.data);\n  } catch (error) {\n    if (error.response) {\n      res.status(error.response.status).json(error.response.data);\n    } else {\n      res.status(500).json({ error: 'Internal Server Error', message: error.message });\n    }\n  }\n});\n\napp.listen(port, () => {\n  console.log(`Server is running on port ${port}`);\n});\n","path":"/home/user/app/index.js"}}}
