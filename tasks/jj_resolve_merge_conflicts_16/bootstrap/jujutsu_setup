#!/bin/bash
set -e

export EDITOR=true

WORK_DIR="${BOOTSTRAP_WORK_DIR:-./.bootstrap_work/current}"
WORK_HOME="${BOOTSTRAP_HOME:-$WORK_DIR/home/user}"

rm -rf "$WORK_DIR"
mkdir -p "$WORK_HOME"

REPO_DIR="$WORK_HOME/repo"
jj git init "$REPO_DIR"
cd "$REPO_DIR"
jj config set --repo user.name "Test User"
jj config set --repo user.email "test@example.com"

# Create initial commit
cat << 'EOF' > app.py
def main():
    pass
EOF
jj describe -m "Initial commit"
jj bookmark create main -r @

# Create feature-a
jj new main -m "Add Feature A"
cat << 'EOF' > app.py
def main():
    print("Feature A")
EOF
jj bookmark create feature-a -r @

# Create feature-b
jj new main -m "Add Feature B"
cat << 'EOF' > app.py
def main():
    print("Feature B")
EOF
jj bookmark create feature-b -r @

# Leave working copy at main, so the user has to do `jj new feature-a feature-b`
jj new main -m "Working copy"

echo "Bootstrap complete: $REPO_DIR"
