#!/bin/bash
set -e

export EDITOR=true

WORK_DIR="${BOOTSTRAP_WORK_DIR:-./.bootstrap_work/current}"
WORK_HOME="${BOOTSTRAP_HOME:-$WORK_DIR/home/user}"

rm -rf "$WORK_DIR"
mkdir -p "$WORK_HOME"

REPO_DIR="$WORK_HOME/repo"

# Initialize jj repo
jj git init "$REPO_DIR"
cd "$REPO_DIR"

# Configure user
jj config set --repo user.name "Test User"
jj config set --repo user.email "test@example.com"

# Commit 1: Initial setup
echo "initial content" > file.txt
jj describe -m "Initial setup"

# Commit 2: feat: add login
jj new
echo "login feature" > login.txt
jj describe -m "feat: add login"

# Commit 3: experiment: try auth v1
jj new
echo "experiment 1" > exp1.txt
jj describe -m "experiment: try auth v1"

# Commit 4: feat: add logout
jj new
echo "logout feature" > logout.txt
jj describe -m "feat: add logout"

# Commit 5: experiment: try auth v2
jj new
echo "experiment 2" > exp2.txt
jj describe -m "experiment: try auth v2"

# Commit 6: feat: user profile
jj new
echo "user profile feature" > profile.txt
jj describe -m "feat: user profile"

echo "Bootstrap complete: $REPO_DIR"
