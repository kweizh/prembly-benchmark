#!/usr/bin/env bash
set -euo pipefail

# Create a bare git repo as the remote
mkdir -p /home/user/origin.git
cd /home/user/origin.git
git init --bare

# Setup divergence-repo
cd /home/user
jj git clone origin.git divergence-repo
cd divergence-repo
jj new "root()" -m "base"
echo "Base" > base.txt
jj bookmark create feature-branch -r @
jj git push --all

# Clone another repo to simulate Machine A
cd /home/user
jj git clone origin.git cloneA
cd cloneA
jj bookmark track feature-branch@origin
jj new feature-branch -m "A"
echo "Machine A changes" > feature.txt
jj bookmark set feature-branch -r @
jj git push --all

# Back to divergence-repo to simulate Machine B
cd /home/user/divergence-repo
jj new feature-branch -m "B"
echo "Machine B changes" > feature.txt
jj bookmark set feature-branch -r @
jj git fetch

# Now divergence-repo has a diverged bookmark `feature-branch`.
