#!/bin/bash
set -euo pipefail

WORK_DIR="${BOOTSTRAP_WORK_DIR:-./.bootstrap_work/current}"
WORK_HOME="${BOOTSTRAP_HOME:-$WORK_DIR/home/user}"

rm -rf "$WORK_HOME/repo"
rm -rf "$WORK_HOME/repo2"
mkdir -p "$WORK_HOME/repo"
cd "$WORK_HOME/repo"

export JJ_USER="Test User"
export JJ_EMAIL="test@example.com"
export JJ_OP_TIMESTAMP="2023-01-01T00:00:00Z"
export JJ_CONFIG="${WORK_HOME}/.jjconfig.toml"

jj git init

# Create the initial commit
jj new 'root()' -m "Initial commit"
echo "Initial" > init.txt
jj new -m "Add feature X"
echo "Version A" > feature_x.txt

CHANGE_ID=$(jj log --no-graph -T 'change_id' -r @)

jj workspace add ../repo2
cd ../repo2
jj edit "$CHANGE_ID"
echo "Version B" > feature_x.txt
jj new -m "Something else"

cd ../repo
jj workspace update-stale
jj workspace forget repo2
rm -rf ../repo2

# Check if it's divergent
jj log
