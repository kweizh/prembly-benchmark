#!/bin/bash
set -e

export EDITOR=true

WORK_DIR="${BOOTSTRAP_WORK_DIR:-./.bootstrap_work/current}"
WORK_HOME="${BOOTSTRAP_HOME:-$WORK_DIR/home/user}"

rm -rf "$WORK_DIR"
mkdir -p "$WORK_HOME"

REPO_DIR="$WORK_HOME/messy-project"
mkdir -p "$REPO_DIR"
cd "$REPO_DIR"

# Initialize jj repo with git backend
jj git init .
jj config set --repo user.name "Test User"
jj config set --repo user.email "test@example.com"

# 1. Initial commit
echo "# Project" > README.md
jj describe -m "Initial commit"
jj new

# 2. Messy commit (Add modules)
echo "def add(a, b): return a - b # Buggy" > math_lib.py
echo "def shout(s): return s.upper()" > string_lib.py
jj describe -m "Add modules"

# 3. Fix commit
jj new
echo "def add(a, b): return a + b # Fixed" > math_lib.py
jj describe -m "Fix math bug"

echo "Bootstrap complete: $REPO_DIR"
