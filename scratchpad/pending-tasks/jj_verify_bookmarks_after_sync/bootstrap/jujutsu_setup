#!/bin/bash
set -euo pipefail

# Create remote repo
mkdir -p /home/user/remote_repo
cd /home/user/remote_repo
git init --bare

# Create a temporary clone to populate the bare repo
cd /home/user
git clone /home/user/remote_repo temp_clone
cd temp_clone
git config user.name "Teammate"
git config user.email "teammate@example.com"
echo "Initial commit" > README.md
git add README.md
git commit -m "Initial commit"
git push origin master

# Create feature-x bookmark and push
git checkout -b feature-x
echo "Feature X base" > feature.txt
git add feature.txt
git commit -m "Feature X base"
git push origin feature-x

# Now create the user's jj repo by cloning the remote
cd /home/user
jj git clone /home/user/remote_repo repo
cd repo
jj config set --user user.name "User"
jj config set --user user.email "user@example.com"

# Track the remote bookmark and create local commit
jj bookmark track feature-x@origin
jj new feature-x -m "Local change to feature X"
echo "Local change" >> feature.txt
jj bookmark move feature-x --to @

# Meanwhile, the teammate pushes a conflicting commit to the remote
cd /home/user/temp_clone
echo "Remote change" >> feature.txt
git add feature.txt
git commit -m "Remote change to feature X"
git push origin feature-x

# Clean up temp clone
rm -rf /home/user/temp_clone

cd /home/user/repo
