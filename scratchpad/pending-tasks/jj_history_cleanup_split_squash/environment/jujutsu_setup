#!/bin/bash
set -e

export EDITOR=true

WORK_DIR="${BOOTSTRAP_WORK_DIR:-./.bootstrap_work/current}"
WORK_HOME="${BOOTSTRAP_HOME:-$WORK_DIR/home/user}"

rm -rf "$WORK_DIR"
mkdir -p "$WORK_HOME"

REPO_DIR="$WORK_HOME/workspace/messy_project"
mkdir -p "$(dirname "$REPO_DIR")"

jj git init "$REPO_DIR"
cd "$REPO_DIR"
jj config set --repo user.name "Test User"
jj config set --repo user.email "test@example.com"

# --- Initial Commit ---
mkdir -p src

cat > src/main.py <<EOF
def main():
    print("Hello")
    raise Exception("Crash")
EOF

cat > README.md <<EOF
# Project
EOF

jj describe -m "initial commit"

# --- WIP Commit ---
jj new

cat > src/logger.py <<EOF
def log(msg):
    print(f"LOG: {msg}")
EOF

cat > src/main.py <<EOF
def main():
    print("Hello")
EOF

cat > README.md <<EOF
# Project
- Added logging
EOF

jj describe -m "wip: all the things"

# --- Working Copy Changes ---
jj new

cat > src/logger.py <<EOF
import sys
def log(msg):
    print(f"LOG: {msg}")
EOF

echo "Bootstrap complete: $REPO_DIR"
