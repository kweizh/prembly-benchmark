#!/bin/bash
set -e

export EDITOR=true

WORK_DIR="${BOOTSTRAP_WORK_DIR:-./.bootstrap_work/current}"
WORK_HOME="${BOOTSTRAP_HOME:-$WORK_DIR/home/user}"

rm -rf "$WORK_DIR"
mkdir -p "$WORK_HOME"

REPO_DIR="$WORK_HOME/repo"

# Initialize repo
jj git init "$REPO_DIR"
cd "$REPO_DIR"

# Configure user identity
jj config set --repo user.name "Test User"
jj config set --repo user.email "test@example.com"

# Create initial commit
echo "init" > init.txt
jj describe -m "initial setup"
jj bookmark create main

# Create the bad commit
jj new -m "temporary debug info"
echo "console.log('debug')" > debug.js

# Create the current working revision
jj new -m "wip feature"
echo "working..." > work.txt
