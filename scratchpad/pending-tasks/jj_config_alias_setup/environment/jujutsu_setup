#!/bin/bash
set -e

export EDITOR=true

WORK_DIR="${BOOTSTRAP_WORK_DIR:-./.bootstrap_work/current}"
WORK_HOME="${BOOTSTRAP_HOME:-$WORK_DIR/home/user}"

rm -rf "$WORK_DIR"
mkdir -p "$WORK_HOME"

REPO_DIR="$WORK_HOME/repo"

# Initialize jj repo
jj git init "$REPO_DIR"
cd "$REPO_DIR"

# Configure user for setup (not the user's identity to be set in task)
jj config set --repo user.name "Repo Admin"
jj config set --repo user.email "admin@example.com"

# Create initial content
echo "# Project Documentation" > README.md

# Create initial commit
jj describe -m "Initial commit"
jj bookmark create main

# Create new working copy on top
jj new

echo "Bootstrap complete: $REPO_DIR"
