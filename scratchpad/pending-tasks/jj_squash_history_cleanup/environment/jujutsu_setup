#!/bin/bash
set -e

export EDITOR=true

WORK_DIR="${BOOTSTRAP_WORK_DIR:-./.bootstrap_work/current}"
WORK_HOME="${BOOTSTRAP_HOME:-$WORK_DIR/home/user}"

rm -rf "$WORK_DIR"
mkdir -p "$WORK_HOME"

REPO_DIR="$WORK_HOME/weather_app"
jj git init "$REPO_DIR"
cd "$REPO_DIR"

# Configure user
jj config set --repo user.name "Test User"
jj config set --repo user.email "test@example.com"

# --- Initial Commit ---
echo "# Weather App" > README.md
jj describe -m "Initial commit"
jj bookmark create main

# --- Commit 1: feat: add rain tracking ---
jj new
echo "def track_rain(amount):" > rain.py
echo "    return amount" >> rain.py
jj describe -m "feat: add rain tracking"

# --- Commit 2: fix: calculation error ---
jj new
echo "def track_rain(amount):" > rain.py
echo "    # Fix: ensure non-negative" >> rain.py
echo "    if amount < 0: return 0" >> rain.py
echo "    return amount" >> rain.py
jj describe -m "fix: calculation error"

# --- Commit 3: docs: update readme ---
jj new
echo "# Weather App" > README.md
echo "" >> README.md
echo "## Features" >> README.md
echo "- Rain tracking" >> README.md
jj describe -m "docs: update readme"

# --- Bookmark ---
jj bookmark create feature/precip

echo "Bootstrap complete: $REPO_DIR"
