#!/bin/bash
set -e

WORK_DIR="${BOOTSTRAP_WORK_DIR:-./.bootstrap_work/current}"
WORK_HOME="${BOOTSTRAP_HOME:-$WORK_DIR/home/user}"

rm -rf "$WORK_DIR"
mkdir -p "$WORK_HOME/repo"

cd "$WORK_HOME/repo"

# Initialize repo (using git backend as 'jj init' might not be available)
jj git init .
jj config set --repo user.name "Test User"
jj config set --repo user.email "test@example.com"

# Base revision (version 1.0)
cat > config.toml <<EOF
[package]
name = "my-app"
version = "1.0"
EOF
jj describe -m "initial config"
jj bookmark create base

# Main branch (update version to 1.1)
jj new base -m "update to 1.1"
cat > config.toml <<EOF
[package]
name = "my-app"
version = "1.1"
EOF
jj bookmark create main

# Feature branch (beta version 1.0-beta)
jj new base -m "set beta version"
cat > config.toml <<EOF
[package]
name = "my-app"
version = "1.0-beta"
EOF
jj bookmark create feature

# Set working copy to feature to be ready for the task
jj edit feature
