#!/bin/bash
set -e

export EDITOR=true

WORK_DIR="${BOOTSTRAP_WORK_DIR:-./.bootstrap_work/current}"
WORK_HOME="${BOOTSTRAP_HOME:-$WORK_DIR/home/user}"

rm -rf "$WORK_DIR"
mkdir -p "$WORK_HOME"

REPO_DIR="$WORK_HOME/repo"
jj git init "$REPO_DIR"
cd "$REPO_DIR"

jj config set --repo user.name "Test User"
jj config set --repo user.email "test@example.com"

mkdir -p src

# 1. Create initial state
cat > src/math_utils.py <<EOF
def add(a, b):
    return a + b
EOF

jj describe -m "initial: add function"

# 2. Create new revision for the feature
jj new

# 3. Implement multiply
cat > src/math_utils.py <<EOF
def add(a, b):
    return a + b

def multiply(a, b):
    return a * b
EOF

jj describe -m "feat: implement multiply"

# 4. Simulate the accident: abandon the current revision
jj abandon @

# At this point, the working copy is a new commit on top of "initial: add function",
# and src/math_utils.py only contains the add function.
